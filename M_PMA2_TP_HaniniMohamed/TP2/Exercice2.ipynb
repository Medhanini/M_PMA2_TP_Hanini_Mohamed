   "source": [
    "import numpy as np\n",
    "def gradient_rosenbrock(x, y):\n",
    "    dfdx = 2*(x - 1) + 400*x*(x**2 - y)\n",
    "    dfdy = -200*(x**2 - y)\n",
    "    return np.array([dfdx, dfdy])\n",
    "print(gradient_rosenbrock(1,1))"
   ]
